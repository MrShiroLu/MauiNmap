<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NmapMaui.NetworkToolsPage">

    <Grid RowDefinitions="Auto,*" Padding="25" BackgroundColor="Transparent">
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Margin="0,10,0,30" Spacing="5">
            <Label Text="> NETWORK_DIAGNOSTICS"
                   TextColor="{StaticResource Primary}"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>
            <Label Text="Active port scanners, host ICMP pings, DNS resolvers &amp; web enumeration"
                   TextColor="{StaticResource TextSecondary}"
                   FontSize="13"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Tool Grid -->
        <Grid Grid.Row="1" 
              RowDefinitions="*,*"
              ColumnDefinitions="*,*,*"
              RowSpacing="20"
              ColumnSpacing="20">

            <!-- Port Scanner -->
            <Frame Grid.Row="0" Grid.Column="0">
                <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="[+] PORT_SCANNER"
                           TextColor="{StaticResource Primary}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Audit target endpoints to determine active TCP ports."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"/>
                    <Button Text="EXECUTE"
                            Clicked="OnPortScannerClicked"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Ping Tool -->
            <Frame Grid.Row="0" Grid.Column="1">
                <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="[+] ICMP_PING"
                           TextColor="{StaticResource Primary}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Send ICMP echo packets to test network connection latency."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"/>
                    <Button Text="EXECUTE"
                            Clicked="OnPingToolClicked"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <!-- DNS Lookup -->
            <Frame Grid.Row="0" Grid.Column="2">
                <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="[+] DNS_RESOLVER"
                           TextColor="{StaticResource Primary}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Perform A/AAAA record DNS resolutions for domains."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"/>
                    <Button Text="EXECUTE"
                            Clicked="OnDnsLookupClicked"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Gobuster -->
            <Frame Grid.Row="1" Grid.Column="0">
                <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="[+] GOBUSTER_WEB"
                           TextColor="{StaticResource Primary}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Fuzz directories and subdomains via HTTP endpoint checks."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"/>
                    <Button Text="EXECUTE"
                            Clicked="OnGobusterClicked"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Netcat -->
            <Frame Grid.Row="1" Grid.Column="1">
                <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="[+] NETCAT_UTILITY"
                           TextColor="{StaticResource Primary}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Establish raw TCP connections or grab active port banners."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"/>
                    <Button Text="EXECUTE"
                            Clicked="OnNetcatClicked"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
