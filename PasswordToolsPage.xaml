<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NmapMaui.PasswordToolsPage">

    <Grid RowDefinitions="Auto,*" Padding="20">
        <Label Text="Password Tools"
               TextColor="#FFFFFF"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,0,0,20"/>

		<Grid Grid.Row="1"
					  RowDefinitions="*,*"
					  ColumnDefinitions="*,*,*"
					  RowSpacing="20"
					  ColumnSpacing="20">
			<Frame Grid.Row="0" Grid.Column="0"
                   BackgroundColor="#23272F"
                   BorderColor="#00BFAE"
                   CornerRadius="10"
                   Padding="15">
				<VerticalStackLayout Spacing="10">
					<Label Text="Password Generator"
                           TextColor="#00BFAE"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
					<Label Text="Generate secure passwords"
                           FontSize="14"
                           HorizontalOptions="Center"/>
					<Button Text="Open"
                            FontAttributes="Bold"
                            Opacity="0.9"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Clicked="OnPasswordGenPageClicked"/>
				</VerticalStackLayout>
			</Frame>

			<Frame Grid.Row="0" Grid.Column="1"
                   BackgroundColor="#23272F"
                   BorderColor="#00BFAE"
                   CornerRadius="10"
                   Padding="15">
				<VerticalStackLayout Spacing="10">
					<Label Text="Password Strength"
                           TextColor="#00BFAE"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
					<Label Text="Check password security"
                           FontSize="14"
                           HorizontalOptions="Center"/>
					<Button Text="Open"
                            FontAttributes="Bold"
                            Opacity="0.9"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Clicked="OnPasswordStrengthPageClicked"/>
				</VerticalStackLayout>
			</Frame>

			<Frame Grid.Row="0" Grid.Column="2"
	               BackgroundColor="#23272F"
	               BorderColor="#00BFAE"
	               CornerRadius="10"
	               Padding="15">
				<VerticalStackLayout Spacing="10">
                    <Label Text="Password Leak Lookup"
                           TextColor="#00BFAE"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
					<Label Text="Resolve hostnames to IP"
                           FontSize="14"
                           HorizontalOptions="Center"/>
					<Button Text="Open"
                            FontAttributes="Bold"
                            Opacity="0.9"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Clicked="OnPasswordLeakCheckPageClicked"/>
				</VerticalStackLayout>
			</Frame>
		</Grid>
    </Grid>
</ContentPage>
