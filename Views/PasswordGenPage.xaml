<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NmapMaui.ViewModels"
             x:Class="NmapMaui.Views.PasswordGenPage"
             x:DataType="vm:PasswordGenViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource Primary}" CornerRadius="4" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Password Generator" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
                    <Entry Text="{Binding Length}" Placeholder="password length" Keyboard="Numeric" BackgroundColor="{StaticResource CardLight}" TextColor="White"/>
                    <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                        <HorizontalStackLayout Spacing="5">
                            <CheckBox IsChecked="{Binding UseUppercase}"/>
                            <Label Text="Uppercase Letters" TextColor="#FFFFFF" VerticalOptions="Center" Margin="-15"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="5">
                            <CheckBox IsChecked="{Binding UseLowercase}"/>
                            <Label Text="Lowercase Letters" TextColor="#FFFFFF" VerticalOptions="Center" Margin="-15"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="5">
                            <CheckBox IsChecked="{Binding UseNumbers}"/>
                            <Label Text="Numbers" TextColor="#FFFFFF" VerticalOptions="Center" Margin="-15"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="5">
                            <CheckBox IsChecked="{Binding UseSpecial}"/>
                            <Label Text="Special Characters" TextColor="#FFFFFF" VerticalOptions="Center" Margin="-15"/>
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>
                    <Button Text="Generate Password"  Command="{Binding GenerateCommand}"/>
                    <Editor Text="{Binding Result}" HeightRequest="200" IsReadOnly="True" BackgroundColor="{StaticResource CardBackground}" TextColor="White"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
