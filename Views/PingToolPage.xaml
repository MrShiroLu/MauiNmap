<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NmapMaui.ViewModels"
             x:Class="NmapMaui.Views.PingToolPage"
             x:DataType="vm:PingToolViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="#23272F" BorderColor="#00BFAE" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Ping Tool"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="#00BFAE"/>

                    <Entry Text="{Binding Host}"
                           Placeholder="Enter host (e.g., 192.168.1.1 or example.com)"
                           BackgroundColor="#2E323D"/>

                    <Button Text="Ping Host"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Opacity="0.9"
                            Command="{Binding PingCommand}"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                     IsVisible="{Binding IsBusy}"
                                     HorizontalOptions="Center"
                                     BackgroundColor="#181A20"/>

                    <Editor Text="{Binding Result}"
                            HeightRequest="200"
                            IsReadOnly="True"
                            BackgroundColor="#181A20"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
