<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NmapMaui.ViewModels"
             x:Class="NmapMaui.Views.EncryptionToolPage"
             x:DataType="vm:EncryptionToolViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource Primary}" CornerRadius="4" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Encryption Tool" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
                    <Editor Text="{Binding Input}" HeightRequest="100" Placeholder="Enter text to encrypt/decrypt" BackgroundColor="{StaticResource CardLight}"/>
                    <Entry Text="{Binding Key}" Placeholder="Enter encryption key" BackgroundColor="{StaticResource CardLight}"/>
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Button Text="Encrypt"  Command="{Binding EncryptCommand}"/>
                        <Button Text="Decrypt"  Command="{Binding DecryptCommand}"/>
                    </HorizontalStackLayout>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Color="#FFFFFF"/>
                    <Editor Text="{Binding Result}" HeightRequest="200" IsReadOnly="True" BackgroundColor="{StaticResource CardBackground}" TextColor="White"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
