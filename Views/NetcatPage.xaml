<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NmapMaui.ViewModels"
             x:Class="NmapMaui.Views.NetcatPage"
             x:DataType="vm:NetcatViewModel">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="#23272F" BorderColor="#00BFAE" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Netcat (Banner Grab)" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#00BFAE"/>
                    <Entry Text="{Binding Host}" Placeholder="Host" BackgroundColor="#2E323D" TextColor="White"/>
                    <Entry Text="{Binding Port}" Placeholder="Port" Keyboard="Numeric" BackgroundColor="#2E323D" TextColor="White"/>
                    <Button Text="Connect" BackgroundColor="#536DFE" TextColor="#FFFFFF" Command="{Binding ConnectCommand}"/>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center"/>
                    <Editor Text="{Binding Output}" HeightRequest="350" IsReadOnly="True" BackgroundColor="#181a20"/>
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Export JSON" BackgroundColor="#00BFAE" TextColor="White" Command="{Binding ExportJsonCommand}"/>
                        <Button Grid.Column="1" Text="Export CSV" BackgroundColor="#00BFAE" TextColor="White" Command="{Binding ExportCsvCommand}"/>
                        <Button Grid.Column="2" Text="Export PDF" BackgroundColor="#00BFAE" TextColor="White" Command="{Binding ExportPdfCommand}"/>
                    </Grid>
                    <Label Text="{Binding StatusMessage}" TextColor="#00BFAE" FontSize="12"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
