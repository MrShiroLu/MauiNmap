<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NmapMaui.ViewModels"
             x:Class="NmapMaui.Views.Base64ToolPage"
             x:DataType="vm:Base64ToolViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource Primary}" CornerRadius="4" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Base64 Tool" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
                    <Editor Text="{Binding Input}" HeightRequest="100" Placeholder="Enter text to encode/decode" BackgroundColor="{StaticResource CardLight}"/>
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Button Text="Encode"  Command="{Binding EncodeCommand}"/>
                        <Button Text="Decode"  Command="{Binding DecodeCommand}"/>
                    </HorizontalStackLayout>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center"/>
                    <Editor Text="{Binding Result}" HeightRequest="200" IsReadOnly="True" BackgroundColor="{StaticResource CardBackground}" TextColor="White"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
