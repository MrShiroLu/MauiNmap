<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NmapMaui.ViewModels"
             x:Class="NmapMaui.Views.GobusterPage"
             x:DataType="vm:GobusterViewModel">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource Primary}" CornerRadius="4" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Gobuster (Directory Buster)" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
                    <Entry Text="{Binding Url}" Placeholder="Target URL" BackgroundColor="{StaticResource CardLight}" TextColor="White"/>
                     <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Entry Grid.Column="0" Text="{Binding Wordlist}" Placeholder="Wordlist path (e.g., C:\tools\common.txt)" BackgroundColor="{StaticResource CardLight}" TextColor="White"/>
                        <Button Grid.Column="1" Text="Browse"  HeightRequest="40" Padding="12,0" FontSize="12" CornerRadius="4" Command="{Binding PickWordlistFileCommand}"/>
                    </Grid>
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="Remote Scan (Minimal API):" VerticalOptions="Center" TextColor="White"/>
                        <Switch IsToggled="{Binding UseRemoteApi}" OnColor="#00BFAE"/>
                    </HorizontalStackLayout>

                    <Button Text="Start Scan"  Command="{Binding ScanCommand}"/>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center"/>
                    <Editor Text="{Binding Output}" HeightRequest="350" IsReadOnly="True" BackgroundColor="{StaticResource CardBackground}"/>
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Export JSON"  Command="{Binding ExportJsonCommand}"/>
                        <Button Grid.Column="1" Text="Export CSV"  Command="{Binding ExportCsvCommand}"/>
                        <Button Grid.Column="2" Text="Export PDF"  Command="{Binding ExportPdfCommand}"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="{Binding StatusMessage}" TextColor="{StaticResource Primary}" FontSize="12" VerticalOptions="Center" LineBreakMode="CharacterWrap"/>
                        <Button Grid.Column="1" Text="Copy Path" IsVisible="{Binding HasSavedPath}"  HeightRequest="32" Padding="12,0" FontSize="11" CornerRadius="4" Command="{Binding CopySavedPathCommand}"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
