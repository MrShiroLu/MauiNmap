<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NmapMaui.DatabaseControlPage"
             BackgroundColor="Transparent">

    <Grid RowDefinitions="Auto,Auto,*" Padding="25">
        <!-- Header -->
        <Label Text="> DATABASE_CONTROL_PANEL"
               TextColor="{StaticResource Primary}"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,10,0,25"/>

        <!-- Selection -->
        <Picker Grid.Row="1" 
                x:Name="_tablePicker" 
                Title="Select Table"
                SelectedIndexChanged="OnTablePickerSelectedIndexChanged"
                Margin="0,0,0,15"
                WidthRequest="250"
                HorizontalOptions="Center"
                TextColor="{StaticResource TextPrimary}"
                BackgroundColor="{StaticResource CardLight}"/>

        <!-- Scrollable Data Section -->
        <ScrollView Grid.Row="2" 
                    x:Name="_scrollView"
                    VerticalOptions="FillAndExpand">
            <ContentView x:Name="_tableContentView">
            </ContentView>
        </ScrollView>
    </Grid>
</ContentPage>
