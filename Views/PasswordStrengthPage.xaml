<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NmapMaui.Views.PasswordStrengthPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="#23272F" BorderColor="#00BFAE" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Password Strength Checker"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="#00BFAE"/>

                    <Editor x:Name="PasswordEditor"
                            HeightRequest="100"
                            Placeholder="Enter password to check"
                            BackgroundColor="#2E323D"
                            TextColor="White"/>

                    <Button Text="Check Strength"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Opacity="0.9"
                            Clicked="OnCheckStrengthClicked"/>

                    <Frame BackgroundColor="#181A20" Padding="10">
                        <VerticalStackLayout Spacing="10">
                            <Label x:Name="StrengthLabel"
                                   Text="Password Strength: Not Checked"
                                   TextColor="#FFFFFF"
                                   FontSize="18"
                                   HorizontalOptions="Center"/>

                            <ProgressBar x:Name="StrengthProgressBar"
                                        Progress="0"
                                        ProgressColor="#00BFAE"/>

                            <Label x:Name="FeedbackLabel"
                                   Text=""
                                   TextColor="#FFFFFF"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage> 