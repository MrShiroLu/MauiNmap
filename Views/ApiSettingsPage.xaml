<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NmapMaui.Views.ApiSettingsPage"
             Title="API Settings">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Başlık -->
            <Label Text="Backend API" FontSize="24" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>

            <!-- ─── Bağlantı ─── -->
            <Label Text="API URL" FontAttributes="Bold" TextColor="White"/>
            <Label Text="Set the base URL of the NmapMaui.Api service." TextColor="LightGray" FontSize="12"/>
            <Entry x:Name="UrlEntry" Placeholder="http://localhost:5000"
                   BackgroundColor="{StaticResource CardLight}" TextColor="White"/>
            <Button Text="Save URL"      Clicked="OnSaveClicked"/>
            <Button Text="Check Health"  Clicked="OnCheckHealthClicked"/>

            <BoxView HeightRequest="1" BackgroundColor="#3A3A3A" Margin="0,5"/>

            <!-- ─── API Login ─── -->
            <Label Text="API Authentication" FontSize="18" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}"/>
            <Label Text="Authenticate with the API to use remote scan features (Nmap / Gobuster)."
                   TextColor="LightGray" FontSize="12"/>

            <Entry x:Name="ApiUsernameEntry" Placeholder="API Username"
                   BackgroundColor="{StaticResource CardLight}" TextColor="White"/>
            <Entry x:Name="ApiPasswordEntry" Placeholder="API Password"
                   IsPassword="True" BackgroundColor="{StaticResource CardLight}" TextColor="White"/>

            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button Text="Login to API"    
                        Clicked="OnApiLoginClicked" WidthRequest="150"/>
                <Button Text="Register on API" 
                        Clicked="OnApiRegisterClicked" WidthRequest="160"/>
            </HorizontalStackLayout>

            <Label x:Name="StatusLabel" TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
