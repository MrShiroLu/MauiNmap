<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NmapMaui.CryptographyToolsPage">

    <Grid RowDefinitions="Auto,*" Padding="20">
        <Label Text="cryptography Tools"
               TextColor="#FFFFFF"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,0,0,20"/>

        <Grid Grid.Row="1" 
              RowDefinitions="*,*"
              ColumnDefinitions="*,*,*"
              RowSpacing="20"
              ColumnSpacing="20">

            <!-- Hash Calculator -->
            <Frame Grid.Row="0" Grid.Column="0"
                   BackgroundColor="#23272F"
                   BorderColor="#00BFAE"
                   CornerRadius="10"
                   Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Hash Calculator"
                           TextColor="#00BFAE"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Calculate various hashes"
                           FontSize="14"
                           HorizontalOptions="Center"/>
                    <Button Text="Open"
                            FontAttributes="Bold"
                            Opacity="0.9"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Clicked="OnHashCalculatorClicked"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Base64 Tool -->
            <Frame Grid.Row="0" Grid.Column="1"
                   BackgroundColor="#23272F"
                   BorderColor="#00BFAE"
                   CornerRadius="10"
                   Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Base64 Tool"
                           TextColor="#00BFAE"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Encode/Decode Base64"
                           FontSize="14"
                           HorizontalOptions="Center"/>
                    <Button Text="Open"
                            FontAttributes="Bold"
                            Opacity="0.9"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Clicked="OnBase64ToolClicked"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Encryption Tool -->
            <Frame Grid.Row="0" Grid.Column="2"
                   BackgroundColor="#23272F"
                   BorderColor="#00BFAE"
                   CornerRadius="10"
                   Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Encryption Tool"
                           TextColor="#00BFAE"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Encrypt/Decrypt text"
                           FontSize="14"
                           HorizontalOptions="Center"/>
                    <Button Text="Open"
                            FontAttributes="Bold"
                            Opacity="0.9"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Clicked="OnEncryptionToolClicked"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
