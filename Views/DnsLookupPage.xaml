<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NmapMaui.ViewModels"
             x:Class="NmapMaui.Views.DnsLookupPage"
             x:DataType="vm:DnsLookupViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource Primary}" CornerRadius="4" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="DNS Lookup" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
                    <Entry Text="{Binding Hostname}" Placeholder="Enter hostname (e.g., example.com)" BackgroundColor="{StaticResource CardLight}"/>
                    <Button Text="Lookup DNS"  Command="{Binding LookupCommand}"/>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Color="#FFFFFF"/>
                    <Editor Text="{Binding Result}" HeightRequest="300" IsReadOnly="True" BackgroundColor="{StaticResource CardBackground}" TextColor="#FFFFFF"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
