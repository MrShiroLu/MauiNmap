<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NmapMaui.Views.LoginPage"
             Title=" "> 

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30,0" VerticalOptions="Center">
            <Image Source="logo.png"
                   SemanticProperties.Description="!Make GUI Great Again!"
                   HeightRequest="400"
                   HorizontalOptions="Center" />

            <Entry x:Name="UsernameEntry"
                   Placeholder="Username"
                   Text="{Binding Username}"
                   SemanticProperties.Hint="Enter your username"/>

            <Entry x:Name="PasswordEntry"
                   Placeholder="Password"
                   IsPassword="True"
                   Text="{Binding Password}"
                   SemanticProperties.Hint="Enter your password"/>

            <HorizontalStackLayout Spacing="25" Padding="30,0" HorizontalOptions="Center">
                <Button x:Name="LoginButton"
                    Text="Login"
                    TextColor="White"
                    FontAttributes="Bold"
                    SemanticProperties.Hint="Click to login"
                    Clicked="OnLoginClicked"
                    HorizontalOptions="Center" />

                <Button x:Name="RegisterButton"
                    Text="Register"
                    TextColor="White"
                    FontAttributes="Bold"
                    SemanticProperties.Hint="Click to register"
                    Clicked="OnRegisterClicked"
                    HorizontalOptions="Center" />
            </HorizontalStackLayout>
            
            <Label x:Name="MessageLabel"
                   Text=""
                   HorizontalOptions="Center"
                   TextColor="Red"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage> 