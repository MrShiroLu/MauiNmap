<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NmapMaui.MainPage">

    <Grid RowDefinitions="Auto,*" Padding="20">
        <Label Text="Security Tools Dashboard"
               TextColor="#FFFFFF"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,0,0,20"/>

        <Grid Grid.Row="1" 
              RowDefinitions="*,*"
              ColumnDefinitions="*,*,*"
              RowSpacing="20"
              ColumnSpacing="20">

            <Frame Grid.Row="0" Grid.Column="0"
                   BackgroundColor="#23272F"                
                   BorderColor="#00BFAE"
                   CornerRadius="10"
                   Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Network Tools"
                           TextColor="#00BFAE"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Analyze network components"
                           FontSize="14"
                           HorizontalOptions="Center"/>
                    <Button Text="Open"
                            FontAttributes="Bold"                            
                            BackgroundColor="#536DFE"
                            Opacity="0.9"
                            TextColor="#FFFFFF"
                            Clicked="OnNetworkToolsClicked"/>
                </VerticalStackLayout>
            </Frame>

            <Frame Grid.Row="0" Grid.Column="1"
                   BackgroundColor="#23272F"
                   BorderColor="#00BFAE"
                   CornerRadius="10"
                   Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Crypto Tools"
                           TextColor="#00BFAE"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Check cryptographic utilities"
                           FontSize="14"
                           HorizontalOptions="Center"/>
                    <Button Text="Open"
                            FontAttributes="Bold"
                            Opacity="0.9"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Clicked="OnCryptotoolsClicked"/>
                </VerticalStackLayout>
            </Frame>

            <Frame Grid.Row="0" Grid.Column="2"
                   BackgroundColor="#23272F"
                   BorderColor="#00BFAE"
                   CornerRadius="10"
                   Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Password Tools"
                           TextColor="#00BFAE"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Generate or manage secure passwords"
                           FontSize="14"
                           HorizontalOptions="Center"/>
                    <Button Text="Open"
                            FontAttributes="Bold"
                            Opacity="0.9"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Clicked="OnPasswordToolsClicked"/>
                </VerticalStackLayout>
            </Frame>

            <Frame Grid.Row="1" Grid.Column="0"
                   BackgroundColor="#23272F"
                   BorderColor="#00BFAE"
                   CornerRadius="10"
                   Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Database Control"
                           TextColor="#00BFAE"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Perform CRUD operations on your databases"
                           FontSize="14"
                           HorizontalOptions="Center"/>
                    <Button Text="Open"
                            FontAttributes="Bold"
                            Opacity="0.9"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Clicked="OnDatabaseControlClicked"/>
                </VerticalStackLayout>
            </Frame>

            <Frame Grid.Row="1" Grid.Column="1"
                   BackgroundColor="#23272F"
                   BorderColor="#00BFAE"
                   CornerRadius="10"
                   Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Change Password"
                           TextColor="#00BFAE"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Change your current password"
                           FontSize="14"
                           HorizontalOptions="Center"/>
                    <Button Text="Open"
                            FontAttributes="Bold"
                            Opacity="0.9"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Clicked="OnChangePasswordPageClicked"/>
                </VerticalStackLayout>
            </Frame>

            <Frame Grid.Row="1" Grid.Column="2"
                   BackgroundColor="#23272F"
                   BorderColor="#00BFAE"
                   CornerRadius="10"
                   Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Login Page"
                           TextColor="#00BFAE"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Login Page"
                           FontSize="14"
                           HorizontalOptions="Center"/>
                    <Button Text="Open"
                            FontAttributes="Bold"
                            Opacity="0.9"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Clicked="OnLoginPageClicked"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
