<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NmapMaui.Views.PingToolPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="#23272F" BorderColor="#00BFAE" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Ping Tool"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="#00BFAE"/>

                    <Entry x:Name="HostEntry"
                           Placeholder="Enter host (e.g., 192.168.1.1 or example.com)"
                           BackgroundColor="#2E323D"/>

                    <Button Text="Ping Host"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Opacity="0.9"
                            Clicked="OnPingClicked"/>

                    <ActivityIndicator x:Name="PingingIndicator"
                                     IsRunning="False"
                                     IsVisible="False"
                                     HorizontalOptions="Center"
                                     BackgroundColor="#181A20"/>

                    <Editor x:Name="ResultEditor"
                            HeightRequest="200"
                            IsReadOnly="True"
                            Text="Ping results will appear here..."
                            BackgroundColor="#181A20"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage> 