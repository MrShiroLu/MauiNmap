<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NmapMaui.ViewModels"
             x:Class="NmapMaui.Views.PortScannerPage"
             x:DataType="vm:PortScannerViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource Primary}" CornerRadius="4" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Port Scanner" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>

                    <Entry Text="{Binding Host}" Placeholder="Enter host (e.g., 192.168.1.1)" BackgroundColor="{StaticResource CardLight}" TextColor="White"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Entry Text="{Binding StartPort}" Placeholder="Start Port" Keyboard="Numeric" BackgroundColor="{StaticResource CardLight}" TextColor="White"/>
                        <Entry Grid.Column="1" Text="{Binding EndPort}" Placeholder="End Port" Keyboard="Numeric" BackgroundColor="{StaticResource CardLight}" TextColor="White"/>
                    </Grid>

                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="Remote Scan (Minimal API):" VerticalOptions="Center" TextColor="White"/>
                        <Switch IsToggled="{Binding UseRemoteApi}" OnColor="#00BFAE"/>
                    </HorizontalStackLayout>

                    <Button Text="Scan Ports"  Command="{Binding ScanCommand}"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center"/>

                    <Editor Text="{Binding Output}" HeightRequest="400" IsReadOnly="True" BackgroundColor="{StaticResource CardBackground}"/>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Export JSON"  Command="{Binding ExportJsonCommand}"/>
                        <Button Grid.Column="1" Text="Export CSV"  Command="{Binding ExportCsvCommand}"/>
                        <Button Grid.Column="2" Text="Export PDF"  Command="{Binding ExportPdfCommand}"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="{Binding StatusMessage}" TextColor="{StaticResource Primary}" FontSize="12" VerticalOptions="Center" LineBreakMode="CharacterWrap"/>
                        <Button Grid.Column="1" Text="Copy Path" IsVisible="{Binding HasSavedPath}"  HeightRequest="32" Padding="12,0" FontSize="11" CornerRadius="4" Command="{Binding CopySavedPathCommand}"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
