<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NmapMaui.ViewModels"
             x:Class="NmapMaui.Views.NetcatPage"
             x:DataType="vm:NetcatViewModel">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="{StaticResource CardBackground}" BorderColor="{StaticResource Primary}" CornerRadius="4" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Netcat (Banner Grab)" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
                    <Entry Text="{Binding Host}" Placeholder="Host" BackgroundColor="{StaticResource CardLight}" TextColor="White"/>
                    <Entry Text="{Binding Port}" Placeholder="Port" Keyboard="Numeric" BackgroundColor="{StaticResource CardLight}" TextColor="White"/>
                    <Button Text="Connect"  Command="{Binding ConnectCommand}"/>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center"/>
                    <Editor Text="{Binding Output}" HeightRequest="350" IsReadOnly="True" BackgroundColor="{StaticResource CardBackground}"/>
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Export JSON"  Command="{Binding ExportJsonCommand}"/>
                        <Button Grid.Column="1" Text="Export CSV"  Command="{Binding ExportCsvCommand}"/>
                        <Button Grid.Column="2" Text="Export PDF"  Command="{Binding ExportPdfCommand}"/>
                    </Grid>
                    <Label Text="{Binding StatusMessage}" TextColor="{StaticResource Primary}" FontSize="12"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
