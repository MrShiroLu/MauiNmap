<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NmapMaui.Views.ChangePasswordPage">
    
    <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">
        <Label Text="Change Password"
               SemanticProperties.HeadingLevel="Level1"
               FontSize="28"
               HorizontalOptions="Center" />

        <Entry x:Name="UsernameEntry"
               Placeholder="Username"
               Text="{Binding Username}"
               SemanticProperties.Hint="Enter the username you want to change the password for"/>

        <Entry x:Name="CurrentPasswordEntry"
               Placeholder="Current Password"
               IsPassword="True"
               Text="{Binding CurrentPassword}"
               SemanticProperties.Hint="Enter your current password"/>

        <Entry x:Name="NewPasswordEntry"
               Placeholder="New Password"
               IsPassword="True"
               Text="{Binding NewPassword}"
               SemanticProperties.Hint="Enter your new password"/>

        <Entry x:Name="ConfirmNewPasswordEntry"
               Placeholder="Confirm New Password"
               IsPassword="True"
               Text="{Binding ConfirmNewPassword}"
               SemanticProperties.Hint="Re-enter your new password"/>

        <Button x:Name="ChangePasswordButton"
                Text="Change Password"
                SemanticProperties.Hint="Click to change your password"
                Clicked="OnChangePasswordClicked"
                HorizontalOptions="Center" />

        <Label x:Name="MessageLabel"
               Text=""
               HorizontalOptions="Center"
               TextColor="Red"/>
    </VerticalStackLayout>
</ContentPage> 