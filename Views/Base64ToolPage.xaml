<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NmapMaui.ViewModels"
             x:Class="NmapMaui.Views.Base64ToolPage"
             x:DataType="vm:Base64ToolViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="#23272F" BorderColor="#00BFAE" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Base64 Tool" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#00BFAE"/>
                    <Editor Text="{Binding Input}" HeightRequest="100" Placeholder="Enter text to encode/decode" BackgroundColor="#2E323D"/>
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Button Text="Encode" BackgroundColor="#536DFE" TextColor="#FFFFFF" Opacity="0.9" Command="{Binding EncodeCommand}"/>
                        <Button Text="Decode" BackgroundColor="#536DFE" TextColor="#FFFFFF" Opacity="0.9" Command="{Binding DecodeCommand}"/>
                    </HorizontalStackLayout>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center"/>
                    <Editor Text="{Binding Result}" HeightRequest="200" IsReadOnly="True" BackgroundColor="#181A20" TextColor="White"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
