<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NmapMaui.MainPage"
             BackgroundImageSource="bg_cyber.png">

    <Grid RowDefinitions="Auto,*" Padding="25" BackgroundColor="Transparent">
        <!-- Dashboard Header -->
        <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Margin="0,10,0,30" Spacing="5">
            <Label Text="> SECURITY_CONTROL_PANEL"
                   TextColor="{StaticResource Primary}"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>
            <Label Text="System diagnostics, cryptography &amp; security utilities"
                   TextColor="{StaticResource TextSecondary}"
                   FontSize="13"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Tool Grid -->
        <Grid Grid.Row="1" 
              RowDefinitions="*,*"
              ColumnDefinitions="*,*,*"
              RowSpacing="20"
              ColumnSpacing="20">

            <!-- Card: Network Tools -->
            <Frame Grid.Row="0" Grid.Column="0">
                <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="[+] NETWORK_TOOLS"
                           TextColor="{StaticResource Primary}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Scan ports, ping hosts, run DNS lookups &amp; packet diagnostics."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"/>
                    <Button Text="EXECUTE"
                            Clicked="OnNetworkToolsClicked"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Card: Crypto Tools -->
            <Frame Grid.Row="0" Grid.Column="1">
                <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="[+] CRYPTO_TOOLS"
                           TextColor="{StaticResource Primary}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Hash calculations, symmetric encryption &amp; Base64 conversion."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"/>
                    <Button Text="EXECUTE"
                            Clicked="OnCryptotoolsClicked"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Card: Password Tools -->
            <Frame Grid.Row="0" Grid.Column="2">
                <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="[+] PASSWORD_TOOLS"
                           TextColor="{StaticResource Primary}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Generate passwords, test strength &amp; audit compromised accounts."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"/>
                    <Button Text="EXECUTE"
                            Clicked="OnPasswordToolsClicked"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Card: Database Control -->
            <Frame Grid.Row="1" Grid.Column="0">
                <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="[+] DATABASE_CONTROL"
                           TextColor="{StaticResource Primary}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Perform database query operations and diagnostic data audits."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"/>
                    <Button Text="EXECUTE"
                            Clicked="OnDatabaseControlClicked"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Card: Change Password -->
            <Frame Grid.Row="1" Grid.Column="1">
                <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="[+] SECURE_AUTH"
                           TextColor="{StaticResource Primary}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Update system credentials and local account authorization settings."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"/>
                    <Button Text="EXECUTE"
                            Clicked="OnChangePasswordPageClicked"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Card: Login Page -->
            <Frame Grid.Row="1" Grid.Column="2">
                <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="[+] ACCOUNT_LOGIN"
                           TextColor="{StaticResource Primary}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Access authentication portal and toggle security active sessions."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"/>
                    <Button Text="EXECUTE"
                            Clicked="OnLoginPageClicked"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
