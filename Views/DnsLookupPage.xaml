<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NmapMaui.Views.DnsLookupPage"
             >

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="#23272F" BorderColor="#00BFAE" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="DNS Lookup"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="#00BFAE"/>

                    <Entry x:Name="HostnameEntry"
                           Placeholder="Enter hostname (e.g., example.com)"
                           BackgroundColor="#2E323D"/>

                    <Button Text="Lookup DNS"
                            BackgroundColor="#536DFE"
                            TextColor="#FFFFFF"
                            Opacity="0.9"
                            Clicked="OnLookupClicked"/>

                    <ActivityIndicator x:Name="LookupIndicator"
                                     IsRunning="False"
                                     IsVisible="False"
                                     HorizontalOptions="Center"
                                     Color="#FFFFFF"/>

                    <Editor x:Name="ResultEditor"
                            HeightRequest="300"
                            IsReadOnly="True"
                            BackgroundColor="#181A20"
                            Text="DNS lookup results will appear here..."
                            TextColor="#FFFFFF"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage> 