<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NmapMaui.ViewModels"
             x:Class="NmapMaui.Views.PasswordLeakCheckPage"
             x:DataType="vm:PasswordLeakCheckViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="#23272F" BorderColor="#00BFAE" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="15" Padding="30,0" VerticalOptions="Center">
                    <Label Text="Password Leak Tool" FontSize="30" HorizontalOptions="Center"/>
                    <Entry Text="{Binding Password}" Placeholder="Enter password" HorizontalOptions="Center"/>
                    <Button Text="Check" TextColor="White" BackgroundColor="#536DFE" Command="{Binding CheckCommand}" HorizontalOptions="Center"/>
                    <Label Text="{Binding Result}" HorizontalOptions="Center"/>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
