<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NmapMaui.ViewModels"
             x:Class="NmapMaui.Views.EncryptionToolPage"
             x:DataType="vm:EncryptionToolViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="#23272F" BorderColor="#00BFAE" CornerRadius="10" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Encryption Tool" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#00BFAE"/>
                    <Editor Text="{Binding Input}" HeightRequest="100" Placeholder="Enter text to encrypt/decrypt" BackgroundColor="#2E323D"/>
                    <Entry Text="{Binding Key}" Placeholder="Enter encryption key" BackgroundColor="#2E323D"/>
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Button Text="Encrypt" BackgroundColor="#536DFE" TextColor="#FFFFFF" Opacity="0.9" Command="{Binding EncryptCommand}"/>
                        <Button Text="Decrypt" BackgroundColor="#536DFE" TextColor="#FFFFFF" Opacity="0.9" Command="{Binding DecryptCommand}"/>
                    </HorizontalStackLayout>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Color="#FFFFFF"/>
                    <Editor Text="{Binding Result}" HeightRequest="200" IsReadOnly="True" BackgroundColor="#181A20" TextColor="White"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
